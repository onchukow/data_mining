# DVSA Credentials
DVSA_LICENCE_NUMBER=XXXXX123456XX9XX
DVSA_BOOKING_REF=12345678          # If you have an existing booking

# Personal Details (for new booking)
APPLICANT_FIRST_NAME=
APPLICANT_LAST_NAME=
APPLICANT_DOB=1995-01-15
APPLICANT_POSTCODE=SW13 9XX
APPLICANT_TITLE=Mr

# Instructor (optional)
INSTRUCTOR_PRN=

# Monitoring Config
TEST_CENTRES=London (Morden),London (Mitcham),London (Tolworth)
EARLIEST_DATE=2026-03-15
LATEST_DATE=2026-06-30
PREFERRED_DAYS=monday,tuesday,wednesday,thursday,friday
PREFERRED_TIME_START=08:00
PREFERRED_TIME_END=17:00
CHECK_INTERVAL_MS=75000
MODE=reschedule                    # reschedule | new_booking
AUTO_BOOK=false                    # true = auto-book, false = notify only
TEST_TYPE=car                      # car | motorcycle | lgv | pcv

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anti-captcha
CAPTCHA_API_KEY=                   # 2captcha.com API key
CAPTCHA_SERVICE=2captcha           # 2captcha | capsolver

# Proxy
PROXY_URL=http://user:pass@proxy.provider.com:PORT
PROXY_TYPE=residential             # residential | mobile

# Payment (use vault in production - doppler/infisical)
# CARD_NUMBER=
# CARD_EXPIRY_MONTH=
# CARD_EXPIRY_YEAR=
# CARD_CVV=
# CARD_NAME=
# BILLING_ADDRESS_LINE1=
# BILLING_CITY=
# BILLING_POSTCODE=

# Logging
LOG_LEVEL=info                     # trace | debug | info | warn | error
SCREENSHOT_DIR=/tmp/screenshots
